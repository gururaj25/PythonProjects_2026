2024-01-15 10:00:10 [INFO] Stored function:
CREATE OR REPLACE FUNCTION calculate_discount(p_customer_id INT, p_amount DECIMAL)
RETURNS DECIMAL AS
BEGIN
    DECLARE @rate DECIMAL = 0.0;
    DECLARE @cnt INT;
    SELECT @cnt = COUNT(*) FROM orders
    WHERE customer_id = p_customer_id AND status = 'completed';
    IF @cnt >= 10 SET @rate = 0.15;
    ELSE IF @cnt >= 5 SET @rate = 0.10;
    RETURN p_amount * @rate;
END;
